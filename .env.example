# ===== Google Gemini =====
# Crie sua chave em https://aistudio.google.com/apikey
GEMINI_API_KEY=
# pro tem fidelidade de OCR de documento muito maior que flash — essencial para
# transcrever corretamente nomes de espécies/científicos em certificados escaneados.
GEMINI_MODEL=gemini-2.5-pro
# Modelos de fallback (separados por vírgula) acionados quando o primário responde
# 503/429 (sobrecarga/limite). Deixe vazio para desativar.
GEMINI_FALLBACK_MODELS=gemini-2.5-flash
GEMINI_MAX_RETRIES=2

# ===== Servidor =====
PORT=3001
CORS_ORIGIN=*

# ===== Upload =====
# Tamanho máximo do arquivo enviado (MB). Acima de ~15-20MB, use a Files API do Gemini.
MAX_UPLOAD_MB=20
